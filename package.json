{
  "name": "xtu-hugo-sample",
  "version": "0.1.0",
  "private": true,
  "description": "XTU slide-style Hugo sample project",
  "scripts": {
    "clean": "rm -rf public resources",
    "preprocess": "node scripts/slide-preprocessor.js",
    "preprocess:clean": "node scripts/slide-preprocessor.js --clean",
    "preprocess:migrate": "node scripts/slide-preprocessor.js --migrate",
    "build": "npm run preprocess && hugo --cleanDestinationDir",
    "export-pdf": "npm run preprocess && node scripts/export-pdf.js",
    "dev": "npm run preprocess && hugo server -D",
    "new": "hugo new slide1/new-slide.md",
    "test": "node --test"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "playwright": "^1.59.1"
  }
}
